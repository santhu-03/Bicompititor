GEMINI_API_KEY=AIzaSyACaWTrD4QhXbdTSW2-yWWnf6aEJSeiRBk

# --- Optional ----------------------------------------------------------------
# MongoDB Atlas connection string. Leave empty to use an in-memory store
# (reports are lost when the server restarts — fine for demos).
MONGODB_URI=mongodb+srv://santhu:dT4D4fOGZFWayEV8@santhu.wsyxysk.mongodb.net/?appName=Santhu

# Gemini model to use. Must be one of the allowlisted models:
# gemini-2.5-flash | gemini-2.5-flash-lite | gemini-2.5-pro |
# gemini-2.0-flash | gemini-2.0-flash-lite
GEMINI_MODEL=gemini-2.5-flash

# Comma-separated list of allowed frontend origins (required in production).
# Example: https://my-app.vercel.app,https://my-custom-domain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000

# Server port
PORT=5000

# Set to "production" when deploying
NODE_ENV=development
